<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>N&amp;A Styling — كوربوريت تحت العباية</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Tajawal:wght@300;400;500;700;900&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#99505C;
    --navy-soft:#B2707B;
    --gold:#C6A15B;
    --gold-soft:#dbc190;
    --beige:#F5DFE0;
    --off:#FFFDFB;
    --line: rgba(153,80,92,0.16);
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;background:var(--off);color:var(--navy);}
  body{font-family:'Jost',sans-serif;font-weight:400;line-height:1.7;-webkit-font-smoothing:antialiased;}
  [dir="rtl"] body, [dir="rtl"] .ar-type{font-family:'Tajawal',sans-serif;}
  h1,h2,h3,.serif{font-family:'Cormorant Garamond',serif;font-weight:500;letter-spacing:.01em;}
  [dir="rtl"] h1,[dir="rtl"] h2,[dir="rtl"] h3,[dir="rtl"] .serif{font-family:'Tajawal',sans-serif;font-weight:700;}
  a{color:inherit;text-decoration:none;}
  button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit;}
  img,svg{display:block;max-width:100%;}
  .eyebrow{
    font-family:'Jost',sans-serif;text-transform:uppercase;letter-spacing:.28em;
    font-size:.72rem;color:var(--gold);font-weight:500;
  }
  [dir="rtl"] .eyebrow{font-family:'Tajawal',sans-serif;letter-spacing:.08em;font-weight:500;}

  /* ---------- Topbar ---------- */
  .topbar{
    position:sticky;top:0;z-index:50;background:rgba(251,248,243,.92);backdrop-filter:blur(6px);
    border-bottom:1px solid var(--line);
  }
  .topbar-inner{
    max-width:1180px;margin:0 auto;padding:16px 28px;display:flex;align-items:center;justify-content:space-between;gap:20px;
  }
  .logo{display:flex;align-items:baseline;gap:8px;}
  .logo .mark{font-family:'Cormorant Garamond',serif;font-size:1.7rem;font-weight:600;letter-spacing:.04em;}
  .logo .sub{font-size:.62rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);}
  nav.main-nav{display:flex;gap:30px;align-items:center;}
  nav.main-nav button{font-size:.92rem;letter-spacing:.02em;padding:6px 2px;position:relative;color:var(--navy);opacity:.72;}
  [dir="rtl"] nav.main-nav button{font-weight:500;}
  nav.main-nav button.active{opacity:1;}
  nav.main-nav button.active::after{
    content:'';position:absolute;left:0;right:0;bottom:-4px;height:2px;background:var(--gold);
  }
  .top-actions{display:flex;align-items:center;gap:14px;}
  .lang-pill{
    display:flex;border:1px solid var(--navy);border-radius:999px;overflow:hidden;font-size:.72rem;letter-spacing:.06em;
  }
  .lang-pill button{padding:6px 14px;opacity:.55;}
  .lang-pill button.active{background:var(--navy);color:var(--off);opacity:1;}
  .burger{display:none;}
  @media(max-width:860px){
    nav.main-nav{position:fixed;inset:64px 0 0 0;background:var(--off);flex-direction:column;justify-content:flex-start;
      padding:30px;gap:22px;transform:translateY(-8px);opacity:0;pointer-events:none;transition:.25s ease;border-top:1px solid var(--line);}
    nav.main-nav.open{opacity:1;pointer-events:auto;transform:translateY(0);}
    nav.main-nav button{font-size:1.1rem;}
    .burger{display:block;font-size:1.4rem;line-height:1;}
  }

  /* ---------- Layout helpers ---------- */
  .wrap{max-width:1180px;margin:0 auto;padding:0 28px;}
  section{padding:96px 0;}
  .band-beige{background:var(--beige);}
  .band-navy{background:var(--navy);color:var(--off);}
  .band-navy .eyebrow{color:var(--gold);}
  .center{text-align:center;}
  .btn{
    display:inline-block;padding:14px 34px;border:1px solid var(--navy);border-radius:2px;font-size:.86rem;
    letter-spacing:.08em;text-transform:uppercase;transition:.2s;
  }
  [dir="rtl"] .btn{letter-spacing:.02em;text-transform:none;font-weight:500;}
  .btn-solid{background:var(--navy);color:var(--off);}
  .btn-solid:hover{background:var(--navy-soft);}
  .btn-outline:hover{background:var(--navy);color:var(--off);}
  .btn-gold{background:var(--gold);border-color:var(--gold);color:var(--navy);font-weight:600;}
  .btn-gold:hover{background:var(--gold-soft);}
  .divider{width:64px;height:1px;background:var(--gold);margin:22px auto;}
  [dir="ltr"] .divider.left, [dir="rtl"] .divider.left{margin-inline:0;}

  /* ---------- Hero / layering signature ---------- */
  .hero{padding:120px 0 80px;}
  .hero-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:60px;align-items:center;}
  @media(max-width:900px){.hero-grid{grid-template-columns:1fr;}}
  .hero h1{font-size:3.1rem;line-height:1.15;margin:.3em 0;}
  .hero p.lead{font-size:1.05rem;max-width:46ch;opacity:.82;}
  .hero-actions{display:flex;gap:16px;margin-top:34px;flex-wrap:wrap;}

  .layer-stage{position:relative;aspect-ratio:3/4;max-width:380px;margin-inline-start:auto;}
  .layer-stage .tag{
    position:absolute;font-size:.68rem;letter-spacing:.15em;text-transform:uppercase;color:var(--navy);
    background:var(--off);border:1px solid var(--line);padding:3px 9px;border-radius:999px;
  }
  [dir="rtl"] .layer-stage .tag{letter-spacing:.02em;text-transform:none;}
  .layer-stage svg{width:100%;height:100%;}
  .abaya-panel{transform-origin:50% 8%;animation:openAbaya 1.6s cubic-bezier(.16,1,.3,1) both;animation-delay:.3s;}
  @keyframes openAbaya{
    0%{transform:rotate(0deg);}
    100%{transform:rotate(-16deg);}
  }
  @media (prefers-reduced-motion: reduce){ .abaya-panel{animation:none;transform:rotate(-16deg);} }

  /* ---------- Section titles ---------- */
  .section-head{max-width:640px;margin:0 auto 56px;text-align:center;}
  .section-head h2{font-size:2.3rem;margin:.25em 0;}

  /* ---------- About ---------- */
  .values{display:grid;grid-template-columns:repeat(3,1fr);gap:30px;margin-top:50px;}
  @media(max-width:760px){.values{grid-template-columns:1fr;}}
  .value-card{background:var(--off);padding:34px 28px;border:1px solid var(--line);}
  .value-card .num{font-family:'Cormorant Garamond',serif;color:var(--gold);font-size:1.6rem;}
  [dir="rtl"] .value-card .num{font-family:'Tajawal',sans-serif;}
  .story-cols{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;}
  @media(max-width:820px){.story-cols{grid-template-columns:1fr;}}

  /* ---------- Lookbook ---------- */
  .look-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:36px;}
  @media(max-width:760px){.look-grid{grid-template-columns:1fr;}}
  .look-card{background:var(--off);border:1px solid var(--line);}
  .look-visual{aspect-ratio:4/5;background:var(--beige);position:relative;overflow:hidden;}
  .look-visual svg{position:absolute;inset:0;width:100%;height:100%;}
  .look-body{padding:26px 28px 30px;}
  .look-tag{font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);}
  [dir="rtl"] .look-tag{letter-spacing:.02em;text-transform:none;font-weight:600;}
  .look-body h3{font-size:1.5rem;margin:.3em 0 .2em;}
  .look-pair{font-size:.86rem;opacity:.75;margin-top:10px;}

  /* ---------- Shop ---------- */
  .filter-row{display:flex;gap:10px;justify-content:center;margin-bottom:44px;flex-wrap:wrap;}
  .filter-pill{border:1px solid var(--navy);padding:8px 20px;border-radius:999px;font-size:.82rem;opacity:.6;}
  .filter-pill.active{background:var(--navy);color:var(--off);opacity:1;}
  .product-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;}
  @media(max-width:900px){.product-grid{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:560px){.product-grid{grid-template-columns:1fr;}}
  .product-card{background:var(--off);border:1px solid var(--line);display:flex;flex-direction:column;}
  .product-visual{aspect-ratio:1/1.1;background:var(--beige);padding:20px;}
  .product-visual svg{width:100%;height:100%;}
  .product-info{padding:20px 22px 24px;display:flex;flex-direction:column;gap:6px;flex:1;}
  .product-info h3{font-size:1.25rem;margin:0;}
  .product-info .desc{font-size:.82rem;opacity:.7;min-height:2.6em;}
  .product-row{display:flex;align-items:center;justify-content:space-between;margin-top:10px;}
  .product-row-center{justify-content:flex-start;}
  .price{font-family:'Cormorant Garamond',serif;font-size:1.25rem;color:var(--navy);}
  [dir="rtl"] .price{font-family:'Tajawal',sans-serif;font-weight:700;}
  .add-btn{font-size:.76rem;letter-spacing:.06em;text-transform:uppercase;border:1px solid var(--navy);padding:9px 16px;transition:.2s;}
  [dir="rtl"] .add-btn{text-transform:none;}
  .add-btn:hover{background:var(--navy);color:var(--off);}
  .soon-pill{border-radius:999px;opacity:.65;pointer-events:none;background:var(--beige);border-color:transparent;}
  .shop-banner{
    max-width:760px;margin:0 auto 44px;text-align:center;background:var(--beige);border:1px solid var(--line);
    padding:14px 22px;border-radius:4px;font-size:.86rem;letter-spacing:.01em;
  }
  .shop-banner .dot{color:var(--gold);margin-inline-end:6px;}

  /* ---------- Contact ---------- */
  .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;}
  @media(max-width:820px){.contact-grid{grid-template-columns:1fr;}}
  .contact-list{list-style:none;padding:0;margin:24px 0 0;display:flex;flex-direction:column;gap:16px;}
  .contact-list li{display:flex;gap:12px;align-items:center;font-size:.95rem;}
  .contact-list .ico{width:34px;height:34px;border:1px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--gold);flex-shrink:0;}
  form.contact-form{display:flex;flex-direction:column;gap:16px;}
  form.contact-form input, form.contact-form textarea{
    background:transparent;border:none;border-bottom:1px solid var(--line);padding:10px 2px;font-family:inherit;font-size:.95rem;color:var(--navy);
  }
  form.contact-form input:focus, form.contact-form textarea:focus{outline:none;border-color:var(--gold);}
  form.contact-form label{font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;opacity:.6;}
  [dir="rtl"] form.contact-form label{letter-spacing:.02em;text-transform:none;}

  /* ---------- Footer ---------- */
  footer{padding:50px 0;border-top:1px solid var(--line);}
  .foot-inner{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px;}
  .foot-tag{font-size:.8rem;opacity:.65;}
  .swatches{display:flex;gap:6px;}
  .swatches span{width:14px;height:14px;border-radius:50%;display:inline-block;}

  .toast{
    position:fixed;bottom:26px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--navy);color:var(--off);
    padding:14px 26px;border-radius:4px;font-size:.86rem;opacity:0;pointer-events:none;transition:.3s;z-index:120;
  }
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

  ::selection{background:var(--gold);color:var(--navy);}
  :focus-visible{outline:2px solid var(--gold);outline-offset:2px;}

  /* ---------- Fine-tuned mobile (iPhone) & laptop polish ---------- */
  @media(max-width:600px){
    .wrap{padding:0 20px;}
    .topbar-inner{padding:14px 20px;}
    .logo .mark{font-size:1.45rem;}
    section{padding:64px 0;}
    .hero{padding:56px 0 48px;}
    .hero h1{font-size:2.15rem;line-height:1.2;}
    .hero p.lead{font-size:.96rem;}
    .hero-grid{gap:40px;}
    .hero-actions{gap:12px;}
    .hero-actions .btn{padding:12px 22px;font-size:.8rem;flex:1;text-align:center;}
    .layer-stage{max-width:230px;margin-inline:auto;}
    .layer-stage .tag{font-size:.6rem;padding:2px 7px;}
    .section-head h2{font-size:1.8rem;}
    .band-navy .wrap h2{font-size:1.5rem;}
    .band-navy .wrap p{font-size:.92rem;}
    .filter-row{gap:8px;}
    .filter-pill{padding:7px 14px;font-size:.76rem;}
    .look-body, .product-info{padding:18px 18px 20px;}
  }
  @media(min-width:1400px){
    .wrap{max-width:1280px;}
    .hero h1{font-size:3.5rem;}
  }
</style>
</head>
