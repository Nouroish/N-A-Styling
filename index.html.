          <ul class="contact-list">
            <li><span class="ico">◐</span> ${c.whatsapp}: +966 5X XXX XXXX</li>
            <li><span class="ico">◑</span> ${c.instagram}: @naa.styling</li>
            <li><span class="ico">◒</span> ${c.email}: hello@naastyling.com</li>
          </ul>
        </div>
        <form class="contact-form" onsubmit="return sendContact(event)">
          <div><label>${c.formName}</label><input type="text" required></div>
          <div><label>${c.formEmail}</label><input type="email" required></div>
          <div><label>${c.formMsg}</label><textarea rows="4" required></textarea></div>
          <button class="btn btn-solid" type="submit" style="align-self:flex-start;margin-top:6px;">${c.formSend}</button>
        </form>
      </div>
    </div>
  </section>`;
}

function renderFooter(){
  const c = t().footer;
  return `
  <footer>
    <div class="wrap foot-inner">
      <div class="foot-tag serif" style="font-size:1rem;">${c.tag}</div>
      <div class="swatches">
        <span style="background:#1B2A41"></span><span style="background:#C6A15B"></span>
        <span style="background:#ECE1CD"></span><span style="background:#FBF8F3;border:1px solid var(--line)"></span>
      </div>
    </div>
  </footer>`;
}

function renderPage(){
  let body = '';
  if(state.page==='home') body = renderHome();
  else if(state.page==='about') body = renderAbout();
  else if(state.page==='lookbook') body = renderLookbook();
  else if(state.page==='shop') body = renderShop();
  else if(state.page==='contact') body = renderContact();
  document.getElementById('app').innerHTML = `<div class="topbar">${renderTopbar()}</div>${body}${renderFooter()}`;
}

/* ================= NAV / LANG / FILTER ================= */
function goto(page){
  state.page = page; state.navOpen = false;
  window.scrollTo({top:0, behavior:'smooth'});
  renderPage();
}
function toggleNav(){
  state.navOpen = !state.navOpen;
  renderPage();
}
function setLang(lang){
  state.lang = lang;
  const c = COPY[lang];
  document.documentElement.setAttribute('dir', c.dirAttr);
  document.documentElement.setAttribute('lang', c.htmlLang);
  renderPage();
}
function setFilter(f){
  state.filter = f;
  renderPage();
}
function sendContact(e){
  e.preventDefault();
  showToast(state.lang==='ar' ? 'شكراً لتواصلك، سنرد قريباً' : 'Thanks for reaching out — we\u2019ll reply soon');
  e.target.reset();
  return false;
}
function showToast(msg){
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(()=>el.classList.remove('show'), 2600);
}

renderPage();
</script>
</body>
</html>
